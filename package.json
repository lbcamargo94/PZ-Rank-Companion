{
  "name": "pz-rank-companion",
  "version": "1.3.5",
  "description": "PZ Community Rank - Auto-sync companion",
  "author": "lbcamargo94",
  "main": "main.js",
  "scripts": {
    "start": "SET ELECTRON_RUN_AS_NODE=&& electron .",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.pzrank.companion",
    "productName": "PZ Rank Companion",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "lbcamargo94",
      "repo": "PZ-Rank-Companion",
      "releaseType": "release"
    },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "PZ.Rank.Companion.${version}.${ext}",
      "sign": null,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "PZ.Rank.Companion.Setup.${version}.exe"
    },
    "portable": {
      "artifactName": "PZ.Rank.Companion.${version}.exe"
    }
  }
}